<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.eschoe.hexagonal.user.adapter.out.persistence.UserMapper">

    <resultMap id="userResult" type="io.github.eschoe.hexagonal.user.adapter.out.persistence.UserEntity">
        <id property="id" column="id"/>
        <result property="email" column="email"/>
        <result property="name" column="name"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="userResult">
        SELECT id, email, name, created_at
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findByEmail" resultMap="userResult">
        SELECT id, email, name, created_at
        FROM users
        WHERE email = #{email}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (email, name, created_at)
        VALUES (#{email}, #{name}, #{createdAt})
    </insert>

    <update id="update">
        UPDATE users
        SET name = #{name}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM users WHERE id = #{id}
    </delete>

</mapper>
